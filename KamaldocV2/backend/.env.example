# --- Core ---
ENV=local
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-32-byte-random
APP_PORT=8000

# --- Database ---
# Local: SQLite. Production (Hetzner): PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./storage/kdoc.db
# DATABASE_URL=postgresql+asyncpg://kdoc:kdoc@localhost:5432/kdoc

# --- Auth (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
# Optional, only for backend admin tasks
SUPABASE_SERVICE_KEY=

# --- LLM (Mistral) ---
MISTRAL_API_KEY=
MISTRAL_TEXT_MODEL=mistral-large-latest
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_TIMEOUT_SECONDS=30

# --- Object Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kdoc-documents
R2_REGION=auto
R2_PUBLIC_URL=

# --- Cache / Queue (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# --- Firebase Cloud Messaging ---
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# --- Sentry ---
SENTRY_DSN=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8100
