# === KamalDoc Backend – Environment Variables ===
# Copy this file to .env and fill in real values.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Google OAuth (Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gmail OAuth (Mailbox-Verbindung, gmail.readonly Scope)
# Falls leer, wird GOOGLE_CLIENT_ID/SECRET als Fallback verwendet.
# Empfohlen: separater OAuth-Client in der Google Cloud Console mit gmail.readonly Scope.
# Die Client-ID muss mit VITE_GMAIL_CLIENT_ID im Frontend übereinstimmen.
GMAIL_CLIENT_ID=246007067980-44qma6u29hu8eiimp7f1n5akqo3k0j3p.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_BASIC_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# Mistral AI (OCR + Text)
MISTRAL_API_KEY=your-mistral-key
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_TEXT_MODEL=mistral-large-latest

# Firebase Cloud Messaging (FCM V1)
FCM_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=/etc/kdoc/your-firebase-adminsdk.json

# URLs
API_URL=https://api.kdoc.at
FRONTEND_URL=https://kamaldoc-flax.vercel.app
ANDROID_CALLBACK=at.kamaldoc.app://callback

# Admin
# Comma-separated Supabase user UUIDs that are seeded as admins on startup.
# The first entry is treated as the "permanent" admin (cannot be removed via API).
ADMIN_USER_IDS=
